{
	"name": "Agg",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DelimitedText3",
						"type": "DatasetReference"
					},
					"name": "Fuentededatos"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "AzureSqlDatabase1",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CANAL as string,",
				"          CANAL_DESC as string,",
				"          TIENDAID as string,",
				"          TIENDADES as string,",
				"          FECHA as string,",
				"          TICKET as string,",
				"          VENDEDOR as string,",
				"          VENDEDORNOMBRE as string,",
				"          TERMINAL as string,",
				"          DEPTO as string,",
				"          DEPTO_DESC as string,",
				"          DIVISION as string,",
				"          DIVISION_DESC as string,",
				"          MONTO_TOTAL as string,",
				"          NOMBRE as string,",
				"          APELLIDOPATERNO as string,",
				"          APELLIDOMATERNO as string,",
				"          TEL as string,",
				"          CEL as string,",
				"          EMAIL as string,",
				"          TIPOPLASTICOID as string,",
				"          TIPOPLASTICODES as string,",
				"          EDAD as string,",
				"          SEXO as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> Fuentededatos",
				"Fuentededatos aggregate(groupBy(CANAL,",
				"          CANAL_DESC),",
				"     Total = count()) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo',",
				"     tableName: 'sumarizado',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}