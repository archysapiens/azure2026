						}
					],
					"transformations": [
						{
							"name": "aggregate1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          CANAL as string,",
						"          CANAL_DESC as string,",
						"          TIENDAID as string,",
						"          TIENDADES as string,",
						"          FECHA as string,",
						"          TICKET as string,",
						"          VENDEDOR as string,",
						"          VENDEDORNOMBRE as string,",
						"          TERMINAL as string,",
						"          DEPTO as string,",
						"          DEPTO_DESC as string,",
						"          DIVISION as string,",
						"          DIVISION_DESC as string,",
